# Office Open XML zipをGit登録時に正規化し、差分表示時は展開済みXMLとして扱う
*.pptx filter=ooxml diff=ooxml merge=ooxml-append
*.pptm filter=ooxml diff=ooxml merge=ooxml-append
*.docx filter=ooxml diff=ooxml merge=ooxml-append
*.docm filter=ooxml diff=ooxml merge=ooxml-append
*.xlsx filter=ooxml diff=ooxml merge=ooxml-append
*.xlsm filter=ooxml diff=ooxml merge=ooxml-append
*.xltx filter=ooxml diff=ooxml merge=ooxml-append
*.xltm filter=ooxml diff=ooxml merge=ooxml-append
*.xlmx filter=ooxml diff=ooxml merge=ooxml-append

# 旧形式Officeファイルはzipではないため、正規化せずバイナリとして扱う
*.ppt binary
*.doc binary
*.xls binary
